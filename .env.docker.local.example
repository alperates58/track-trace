# Local Docker defaults. Copy to .env.docker.local if you want to override values.
API_PORT=18080
FRONTEND_PORT=3000
FRONTEND_URL=http://localhost:3000
VITE_API_BASE_URL=http://localhost:18080
ASPNETCORE_ENVIRONMENT=Production

DB_USER=postgres
DB_PASSWORD=local_postgres_password

JWT_SECRET=local_jwt_secret_minimum_32_chars_12345
JWT_EXPIRY_HOURS=24

ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_NAME=System Administrator

MAX_UPLOAD_MB=100
APP_VERSION=v0.1.0-mvp-local
BUILD_DATE=2026-06-21
GIT_COMMIT_SHA=local
